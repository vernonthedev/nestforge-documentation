---
import '../styles/not-found.css';
import faviconSrc from '../assets/favicon.ico';
import logoSrc from '../assets/logo.svg?url';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 | NestForge</title>
    <meta
      name="description"
      content="The page you requested could not be found in the NestForge documentation site."
    />
    <script is:inline>
      (() => {
        const key = 'nestforge-home-theme';
        const stored = localStorage.getItem(key);
        const theme =
          stored === 'light' || stored === 'dark'
            ? stored
            : window.matchMedia('(prefers-color-scheme: light)').matches
              ? 'light'
              : 'dark';
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <link rel="icon" href={faviconSrc} type="image/x-icon" />
    <link rel="shortcut icon" href={faviconSrc} type="image/x-icon" />
  </head>
  <body class="nf404-body">
    <main class="nf404-shell">
      <div class="nf404-card">
        <a href="/" class="nf404-brand" aria-label="NestForge home">
          <img src={logoSrc} alt="NestForge" />
          <span>NestForge</span>
        </a>

        <p class="nf404-kicker">Page not found</p>
        <h1>That route does not exist in this docs workspace.</h1>
        <p class="nf404-copy">
          The page may have moved, the slug may be wrong, or the link may point to an
          older docs path.
        </p>

        <div class="nf404-actions">
          <a href="/" class="nf404-button nf404-button-primary">Go Home</a>
          <a href="/getting-started/quick-start/" class="nf404-button nf404-button-secondary">Open Quick Start</a>
        </div>

        <div class="nf404-links">
          <a href="/concepts/architecture/">Architecture</a>
          <a href="/guides/testing/">Testing Guide</a>
          <a href="/framework/crate-architecture/">Crate Architecture</a>
          <a href="https://github.com/vernonthedev/nestforge">GitHub</a>
        </div>
      </div>
    </main>
    <script is:inline>
      (() => {
        const key = 'nestforge-home-theme';
        const root = document.documentElement;
        const media = window.matchMedia('(prefers-color-scheme: light)');

        const getStoredTheme = () => {
          const stored = localStorage.getItem(key);
          if (stored === 'light' || stored === 'dark') return stored;
          return null;
        };

        const getSystemTheme = () => (media.matches ? 'light' : 'dark');

        const setTheme = (theme) => {
          root.dataset.theme = theme;
        };

        setTheme(getStoredTheme() ?? getSystemTheme());

        media.addEventListener('change', () => {
          if (!getStoredTheme()) setTheme(getSystemTheme());
        });
      })();
    </script>
  </body>
</html>
